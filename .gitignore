__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/
*.egg-info/
.coverage
.tox/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs / Backups
*.log
*.bak
worker.log

# Generierte Docs (Quelle ist DOKU.md)
DOKU.html
DOKU.pdf
