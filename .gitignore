# Datenbank — wird beim ersten Container-Start automatisch via
# init_db() angelegt (leere Tabellenstruktur). Echte Daten liegen
# unter /docker/research/data/ und gehoeren NICHT ins Repo.
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.filepart

# Streamlit-Geheimnisse (falls je benoetigt)
.streamlit/secrets.toml

